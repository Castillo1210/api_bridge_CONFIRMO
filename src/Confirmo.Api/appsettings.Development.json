{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "Database": {
    "Host": "localhost",
    "Port": 5432,
    "Name": "confirmo",
    "User": "postgres",
    "Password": "postgres"
  },
  "Gcp": {
    "ProjectId": "dev-project",
    "StorageBucket": "confirmo-vouchers-dev",
    "DocumentAiProcessor": ""
  },
  "Jwt": {
    "Secret": "dev-secret-key-minimum-32-characters-long-for-testing",
    "AccessTokenHours": 8,
    "RefreshTokenDays": 30,
    "Issuer": "confirmo-api",
    "Audience": "confirmo-app"
  },
  "Redis": {
    "Host": "localhost",
    "Port": 6379
  },
  "PythonWorker": {
    "BaseUrl": "http://localhost:8081"
  },
  "FinanceWebhook": {
    "Url": "http://host.docker.internal:3000/webhook/deposito",
    "Secret": "dev-webhook-secret"
  }
}
